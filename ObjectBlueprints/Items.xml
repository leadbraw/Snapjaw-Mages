<?xml version="1.0" encoding="utf-8" ?>
<objects>
    <object Name="Leadbraw_SnapjawMage_Magic Tome" Inherits="BaseMissileWeapon">
        <tag Name="BaseObject" Value="*noinherit" />
        <tag Name="Tier" Value="2" />
        <!-- no tinkering allowed! -->
        <tag Name="Mods" Value="" />

        <!-- Same description as StandaloneMarkovBook -->
        <part Name="Description" Short="Crisp pages of goatskin vellum are bound into a codex." />
        <part Name="Physics" Weight="1" UsesTwoSlots="true" />
        <part Name="Commerce" Value="80" />
    </object>

    <object Name="Leadbraw_SnapjawMage_Fire Tome" Inherits="Leadbraw_SnapjawMage_Magic Tome">
        <part Name="Render" DisplayName="tome of {{R|fire}}" Tile="Items/sw_book_1.bmp" ColorString="&amp;R" DetailColor="Y" />
        <part Name="MissileWeapon" AmmoChar="f" ShotsPerAction="1" AmmoPerAction="1" ShotsPerAnimation="1" WeaponAccuracy="0" />
        <!-- This part also seen on Spaser pistol/rifle, Di-thermo beam, and blast cannon -->
        <part Name="CooldownAmmoLoader" Cooldown="10" Readout="true" ProjectileObject="Leadbraw_SnapjawMage_ProjectileFireTome" />

        <tag Name="MissileFireSound" Value="flamethrower" />
    </object>

    <object Name="Leadbraw_SnapjawMage_Ice Tome" Inherits="Leadbraw_SnapjawMage_Magic Tome">
        <part Name="Render" DisplayName="tome of {{C|ice}}" Tile="Items/sw_book_1.bmp" ColorString="&amp;C" DetailColor="Y" />
        <part Name="MissileWeapon" AmmoChar="FR" ShotsPerAction="1" AmmoPerAction="1" ShotsPerAnimation="1" WeaponAccuracy="0" />
        <!-- This part also seen on Spaser pistol/rifle, Di-thermo beam, and blast cannon -->
        <part Name="CooldownAmmoLoader" Cooldown="10" Readout="true" ProjectileObject="Leadbraw_SnapjawMage_ProjectileIceTome" />

        <tag Name="MissileFireSound" Value="hiss_low" />
    </object>

    <object Name="Leadbraw_SnapjawMage_Electric Tome" Inherits="Leadbraw_SnapjawMage_Magic Tome">
        <part Name="Render" DisplayName="tome of {{W|electricity}}" Tile="Items/sw_book_1.bmp" ColorString="&amp;W" DetailColor="Y" />
        <part Name="MissileWeapon" AmmoChar="&amp;W*" ShotsPerAction="1" AmmoPerAction="1" ShotsPerAnimation="1" WeaponAccuracy="4" />
        <part Name="ElectricalDischargeLoader" ChargeUse="300" ProjectileObject="Leadbraw_SnapjawMage_ProjectileElectricTome" />

        <tag Name="MissileFireSound" Value="Sounds/Missile/Fires/Pistols/sfx_missile_arcWinder_fire" />
    </object>

    <!-- Copied & tweaked from ProjectileFlamethrower -->
    <object Name="Leadbraw_SnapjawMage_ProjectileFireTome" Inherits="TemporaryProjectile">
        <part Name="Render" DisplayName="{{R|stream of flame}}" ColorString="&amp;R" />
        <part Name="Projectile" BasePenetration="4" BaseDamage="1d4" Attributes="Heat Fire" ColorString="&amp;R" PassByVerb="whoosh" />
        <part Name="TemperatureOnHit" Amount="4d20" Max="false" OnWielderHit="true" />
        <part Name="TemperatureOnEntering" Amount="8d20" Max="false" OnWielderHit="true" />
    </object>

    <!-- Copied & tweaked from ProjectileFreezeRay -->
    <object Name="Leadbraw_SnapjawMage_ProjectileIceTome" Inherits="TemporaryProjectile">
        <part Name="Render" DisplayName="{{C|streak of ice}}" ColorString="&amp;B" />
        <part Name="Projectile" BasePenetration="4" BaseDamage="1d4" Attributes="Cold" ColorString="&amp;B" PassByVerb="crackle" />
        <part Name="TemperatureOnHit" Amount="-4d20" Max="false" OnWielderHit="true" />
        <part Name="TemperatureOnEntering" Amount="-8d20" Max="false" OnWielderHit="true" />
    </object>

    <!-- Copied & tweaked from ProjectileElectroPistol -->
    <object Name="Leadbraw_SnapjawMage_ProjectileElectricTome" Inherits="TemporaryEnergyProjectile">
        <part Name="Render" DisplayName="{{W|ion packet}}" ColorString="&amp;W" />
        <part Name="Projectile" BasePenetration="0" BaseDamage="0" Attributes="Electric" ColorString="&amp;W" PassByVerb="fly" />
        <part Name="DischargeOnHit" DamageRange="4d4" Voltage="200" />
        <tag Name="ImpactSound" Value="Sounds/Missile/Hits/sfx_missile_directEnergy_hit" />
    </object>
</objects>